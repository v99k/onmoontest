{
  "name": "pair-reverse-minesweeper",
  "private": true,
  "version": "1.0.0",
  "description": "",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build --workspace=@game/shared && npm run build --workspace=@game/backend && npm run build --workspace=@game/frontend",
    "dev": "npm-run-all --parallel dev:backend dev:frontend",
    "dev:backend": "npm run start:dev --workspace=@game/backend",
    "dev:frontend": "npm run dev --workspace=@game/frontend",
    "lint": "npm run lint --workspaces --if-present",
    "format": "npm run format --workspaces --if-present"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5",
    "prettier": "^3.4.2"
  },
  "engines": {
    "node": ">=18"
  }
}
